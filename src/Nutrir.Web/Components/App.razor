@using Microsoft.AspNetCore.Components.Endpoints
@using Microsoft.AspNetCore.Identity
@using Nutrir.Core.Entities
@inject IConfiguration Configuration
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en" data-theme="@_resolvedTheme" data-theme-setting="@_themePreference">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <script>
        (function() {
            var s = document.documentElement.getAttribute('data-theme-setting') || localStorage.getItem('theme-preference') || 'system';
            var r = s === 'system'
                ? (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
                : s;
            document.documentElement.setAttribute('data-theme', r);
            document.documentElement.setAttribute('data-theme-setting', s);
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="@Assets["css/design-system.css"]" />
    @if (PaletteCssPath is not null)
    {
        <link rel="stylesheet" href="@Assets[PaletteCssPath]" />
    }
    <link rel="stylesheet" href="@Assets["css/dark.css"]" />
    <link rel="stylesheet" href="@Assets["css/layout.css"]" />
    <link rel="stylesheet" href="@Assets["css/error-pages.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="_content/Radzen.Blazor/css/material-base.css" />
    <link rel="stylesheet" href="@Assets["Nutrir.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/svg+xml" href="nutrir-icon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="apple-touch-icon.png" />
    <HeadOutlet @rendermode="@pageRenderMode" />
</head>

<body>
    <Routes @rendermode="@pageRenderMode" />
    <script src="_framework/blazor.web.js"></script>
    <script src="_content/Radzen.Blazor/Radzen.Blazor.js"></script>
    <script src="lib/chart.js/chart.umd.min.js"></script>
    <script src="js/progress-chart.js"></script>
    <script src="js/reports-chart.js"></script>
    <script src="js/global-search.js"></script>
    <script src="js/ai-panel.js"></script>
    <script src="js/context-menu.js"></script>
    <script src="lib/qrcodejs/qrcode.min.js"></script>
    <script src="js/qr-authenticator.js"></script>
    <script src="js/calendar.js"></script>
    <script src="js/debounce-input.js"></script>
</body>

</html>

@code {
    [CascadingParameter] private HttpContext HttpContext { get; set; } = default!;

    private IComponentRenderMode? pageRenderMode;
    private string _themePreference = "system";
    private string _resolvedTheme = "light";

    private static readonly HashSet<string> KnownPalettes = new(StringComparer.OrdinalIgnoreCase)
    {
        "sage", "pink", "pink-deep", "pink-soft", "pink-mauve", "pink-lilac"
    };

    private string? PaletteCssPath
    {
        get
        {
            var palette = Configuration["Theme:Palette"];
            if (string.IsNullOrWhiteSpace(palette) || !KnownPalettes.Contains(palette))
                return null;
            return $"css/palettes/palette-{palette}.css";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        pageRenderMode = HttpContext.AcceptsInteractiveRouting() ? InteractiveServer : null;

        if (HttpContext.User.Identity?.IsAuthenticated == true)
        {
            var user = await UserManager.GetUserAsync(HttpContext.User);
            if (user is not null && !string.IsNullOrEmpty(user.ThemePreference))
            {
                _themePreference = user.ThemePreference;
                _resolvedTheme = _themePreference == "system" ? "light" : _themePreference;
            }
        }
    }
}
