@* Shared inline SVG logo — colors adapt to the active CSS palette *@

@if (ShowText)
{
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" class="@CssClass">
        <defs>
            <linearGradient id="logoLeafGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color: var(--color-primary)" />
                <stop offset="100%" style="stop-color: var(--color-primary-hover)" />
            </linearGradient>
        </defs>
        <rect x="52" y="45" width="16" height="95" rx="8" style="fill: var(--color-text)" />
        <rect x="132" y="45" width="16" height="95" rx="8" style="fill: var(--color-text)" />
        <path d="M 60 53 C 115 53, 140 85, 140 132 C 85 132, 60 100, 60 53 Z" fill="url(#logoLeafGrad)" />
        <path d="M 60 53 Q 110 85, 140 132" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" fill="none" opacity="0.4" />
        <text x="100" y="178" font-family="system-ui, -apple-system, sans-serif" font-size="28" font-weight="700" style="fill: var(--color-text)" text-anchor="middle" letter-spacing="1.5">Nutrir</text>
    </svg>
}
else
{
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="40 30 120 120" class="@CssClass">
        <defs>
            <linearGradient id="logoIconLeafGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color: var(--color-primary)" />
                <stop offset="100%" style="stop-color: var(--color-primary-hover)" />
            </linearGradient>
        </defs>
        <rect x="52" y="45" width="16" height="95" rx="8" style="fill: var(--color-text)" />
        <rect x="132" y="45" width="16" height="95" rx="8" style="fill: var(--color-text)" />
        <path d="M 60 53 C 115 53, 140 85, 140 132 C 85 132, 60 100, 60 53 Z" fill="url(#logoIconLeafGrad)" />
        <path d="M 60 53 Q 110 85, 140 132" stroke="#ffffff" stroke-width="2.5" stroke-linecap="round" fill="none" opacity="0.4" />
    </svg>
}

@code {
    [Parameter] public bool ShowText { get; set; } = true;
    [Parameter] public string? CssClass { get; set; }
}
